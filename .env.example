# ============================================================
# Cuckoo-Echo 环境变量配置
# 复制此文件为 .env（本地开发）或 .env.docker（Docker Compose）
# ============================================================

# ── 数据库 ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cuckoo
DATABASE_RO_URL=      # 只读副本 DSN（留空则使用主库）

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Milvus 向量数据库 ──
MILVUS_URI=http://localhost:19530

# ── MinIO 对象存储 ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cuckoo-echo

# ── 应用 ──
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── LLM 模型配置 ──
# 支持 Ollama 本地模型、DeepSeek、OpenAI 等 LiteLLM 兼容的提供商
#
# Ollama 本地模型示例：
#   LLM_PRIMARY_MODEL=ollama/qwen3:8b
#   LLM_API_BASE=http://host.docker.internal:11434  (Docker 内访问宿主机)
#   LLM_API_KEY=ollama
#
# DeepSeek 示例：
#   LLM_PRIMARY_MODEL=deepseek-chat
#   LLM_API_BASE=https://api.deepseek.com/v1
#   LLM_API_KEY=sk-xxx
#
# OpenAI 示例：
#   LLM_PRIMARY_MODEL=gpt-4o-mini
#   LLM_API_KEY=sk-xxx
#
LLM_PRIMARY_MODEL=ollama/qwen3:8b
LLM_FALLBACK_MODEL=ollama/qwen3:8b
LLM_API_BASE=http://localhost:11434
LLM_API_KEY=ollama
LLM_FALLBACK_TIMEOUT=30.0

# ── Embedding 模型（RAG 向量化）──
EMBEDDING_MODEL=ollama/qwen3-embedding

# ── Vision 多模态模型（图片理解）──
VISION_MODEL=ollama/qwen3-vl

# ── ASR 语音识别 ──
ASR_MODE=remote
ASR_API_URL=http://localhost:9000
ASR_MODEL=whisper-1

# ── Admin JWT ──
ADMIN_JWT_SECRET=change-me-in-production

# ── Langfuse 可观测性（可选）──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ── Ragas 质量评估阈值（可选）──
RAGAS_FAITHFULNESS_MIN=0.85
RAGAS_CONTEXT_PRECISION_MIN=0.80
RAGAS_CONTEXT_RECALL_MIN=0.75
RAGAS_ANSWER_RELEVANCY_MIN=0.85
