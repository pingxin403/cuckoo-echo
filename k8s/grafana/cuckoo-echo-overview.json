{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request QPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=~\"api-gateway|chat-service|admin-service\"}[1m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service) * 100",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100 }
      }
    },
    {
      "title": "TTFT (Time To First Token)",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ttft_seconds_bucket{service=\"chat-service\"}[5m])) by (le, scenario))",
          "legendFormat": "P50 {{scenario}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ttft_seconds_bucket{service=\"chat-service\"}[5m])) by (le, scenario))",
          "legendFormat": "P95 {{scenario}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ttft_seconds_bucket{service=\"chat-service\"}[5m])) by (le, scenario))",
          "legendFormat": "P99 {{scenario}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Token Consumption",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(llm_tokens_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Active Conversations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(active_threads_gauge{service=\"chat-service\"})"
        }
      ]
    },
    {
      "title": "AI Resolution Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "(1 - sum(rate(hitl_requests_total[1h])) / sum(rate(conversations_total[1h]))) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [
          { "color": "red", "value": 0 },
          { "color": "yellow", "value": 70 },
          { "color": "green", "value": 85 }
        ]}}
      }
    },
    {
      "title": "HITL Transfer Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(hitl_requests_total[1h])) / sum(rate(conversations_total[1h])) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "yellow", "value": 15 },
          { "color": "red", "value": 30 }
        ]}}
      }
    },
    {
      "title": "Rate Limit Rejections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=\"429\"}[5m]))",
          "legendFormat": "429/s"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["cuckoo-echo", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Cuckoo-Echo Overview",
  "uid": "cuckoo-echo-overview"
}
