# Docker Compose environment variables
# Uses container names for service discovery instead of localhost

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cuckoo
REDIS_URL=redis://redis:6379/0
MILVUS_URI=http://milvus:19530
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cuckoo-echo
ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM — use local Ollama (host.docker.internal points to host machine)
LLM_PRIMARY_MODEL=ollama/qwen3:8b
LLM_FALLBACK_MODEL=ollama/qwen3:8b
LLM_API_BASE=http://host.docker.internal:11434
LLM_API_KEY=ollama
LLM_FALLBACK_TIMEOUT=120.0

# Vision LLM (multimodal — requires vision-capable model)
VISION_MODEL=ollama/qwen3-vl

# ASR (Speech-to-Text) — disabled for now
ASR_MODE=remote

# Embedding model (for RAG vector search)
EMBEDDING_MODEL=ollama/qwen3-embedding
